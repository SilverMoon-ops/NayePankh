<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Admin Dashboard Control Panel</title>
</head>
<body class="bg-slate-100 min-h-screen">
    <nav class="bg-white shadow p-4 flex justify-between items-center print:hidden">
        <h1 class="text-xl font-bold text-emerald-600">NayePankh Admin Management Panel</h1>
        <div>
            <button onclick="window.print()" class="bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium mr-2 hover:bg-blue-700">Print Analytics Report</button>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded text-sm font-medium hover:bg-red-600">Log Out</a>
        </div>
    </nav>
    <main class="max-w-6xl mx-auto mt-8 p-4">
        <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="bg-white p-4 rounded-lg shadow text-center"><h4 class="text-gray-500 text-sm font-semibold">Total Evaluated Applicants</h4><p class="text-3xl font-bold text-gray-800"><%= metrics.total %></p></div>
            <div class="bg-white p-4 rounded-lg shadow text-center"><h4 class="text-gray-500 text-sm font-semibold">Approved Personnel</h4><p class="text-3xl font-bold text-green-600"><%= metrics.approved %></p></div>
            <div class="bg-white p-4 rounded-lg shadow text-center"><h4 class="text-gray-500 text-sm font-semibold">Pending Review Decisions</h4><p class="text-3xl font-bold text-amber-500"><%= metrics.pending %></p></div>
        </div>

        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="min-w-full text-left text-sm">
                <thead class="bg-gray-50 uppercase text-xs font-semibold text-gray-700">
                    <tr><th class="p-4">Volunteer Name</th><th class="p-4">Email</th><th class="p-4">Key Skills</th><th class="p-4">Department Program</th><th class="p-4">Review Status</th><th class="p-4 print:hidden">Administrative Actions</th></tr>
                </thead>
                <tbody class="divide-y">
                    <% applicants.forEach(app => { %>
                        <tr>
                            <td class="p-4 font-medium"><%= app.name %></td>
                            <td class="p-4 text-gray-600"><%= app.email %></td>
                            <td class="p-4"><%= app.skills || 'Not Configured Profile' %></td>
                            <td class="p-4"><%= app.interestArea || 'None' %></td>
                            <td class="p-4"><span class="px-2 py-0.5 rounded text-xs font-bold <%= app.status === 'Approved' ? 'bg-green-100 text-green-800' : app.status === 'Rejected' ? 'bg-red-100 text-red-800' : 'bg-amber-100 text-amber-800' %>"><%= app.status %></span></td>
                            <td class="p-4 print:hidden flex space-x-2">
                                <form action="/admin/update-status" method="POST"><input type="hidden" name="id" value="<%= app._id %>"><input type="hidden" name="status" value="Approved"><button class="bg-green-600 text-white px-2 py-1 text-xs rounded hover:bg-green-700">Approve</button></form>
                                <form action="/admin/update-status" method="POST"><input type="hidden" name="id" value="<%= app._id %>"><input type="hidden" name="status" value="Rejected"><button class="bg-red-500 text-white px-2 py-1 text-xs rounded hover:bg-red-600">Reject</button></form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>