<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Admin Dashboard - NayePankh</title>
</head>
<body class="bg-slate-100 min-h-screen">

    <nav class="bg-white shadow p-4 flex justify-between items-center print:hidden">
        <div>
            <h1 class="text-xl font-bold text-emerald-600">NayePankh Admin Panel</h1>
            <p class="text-xs text-gray-400">Logged in as <strong><%= userName %></strong></p>
        </div>
        <div class="flex items-center gap-2">
            <button
                onclick="window.print()"
                class="bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700 transition-colors">
                Print Report
            </button>

            <%# SECURITY FIX: Logout uses POST form instead of <a href="/logout">.
                GET-based logout is vulnerable to CSRF — any external site can embed
                <img src="/logout"> and silently log users out. %>
            <form action="/logout" method="POST" class="inline">
                <button type="submit" class="bg-red-500 text-white px-4 py-2 rounded text-sm font-medium hover:bg-red-600 transition-colors">
                    Log Out
                </button>
            </form>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto mt-8 p-4">

        <%# ── METRICS CARDS ──────────────────────────────────────────────── %>
        <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="bg-white p-4 rounded-lg shadow text-center">
                <h4 class="text-gray-500 text-sm font-semibold uppercase tracking-wide">Total Applicants</h4>
                <p class="text-3xl font-bold text-gray-800 mt-1"><%= metrics.total %></p>
            </div>
            <div class="bg-white p-4 rounded-lg shadow text-center">
                <h4 class="text-gray-500 text-sm font-semibold uppercase tracking-wide">Approved</h4>
                <p class="text-3xl font-bold text-green-600 mt-1"><%= metrics.approved %></p>
            </div>
            <div class="bg-white p-4 rounded-lg shadow text-center">
                <h4 class="text-gray-500 text-sm font-semibold uppercase tracking-wide">Pending Review</h4>
                <p class="text-3xl font-bold text-amber-500 mt-1"><%= metrics.pending %></p>
            </div>
        </div>

        <%# ── APPLICANTS TABLE ────────────────────────────────────────────── %>
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="min-w-full text-left text-sm">
                <thead class="bg-gray-50 uppercase text-xs font-semibold text-gray-600 tracking-wider">
                    <tr>
                        <th class="p-4">Name</th>
                        <th class="p-4">Email</th>
                        <th class="p-4">Skills</th>
                        <th class="p-4">Campaign Area</th>
                        <th class="p-4">Status</th>
                        <th class="p-4 print:hidden">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% if (applicants.length === 0) { %>
                        <tr>
                            <td colspan="6" class="p-6 text-center text-gray-400">No applicants found.</td>
                        </tr>
                    <% } %>

                    <% applicants.forEach(app => { %>
                        <tr class="hover:bg-slate-50 transition-colors">

                            <td class="p-4 font-medium text-gray-900"><%= app.name %></td>
                            <td class="p-4 text-gray-600"><%= app.email %></td>
                            <td class="p-4 text-gray-700"><%= app.skills || '—' %></td>
                            <td class="p-4 text-gray-700"><%= app.interestArea || '—' %></td>

                            <td class="p-4">
                                <span class="px-2 py-0.5 rounded text-xs font-bold
                                    <%= app.status === 'Approved' ? 'bg-green-100 text-green-800' :
                                        app.status === 'Rejected'  ? 'bg-red-100 text-red-800' :
                                                                      'bg-amber-100 text-amber-800' %>">
                                    <%= app.status %>
                                </span>
                            </td>

                            <%# Action buttons — hidden when printing %>
                            <td class="p-4 print:hidden">
                                <div class="flex gap-2">

                                    <%# Approve button %>
                                    <% if (app.status !== 'Approved') { %>
                                        <form action="/admin/update-status" method="POST">
                                            <input type="hidden" name="id"     value="<%= app._id %>">
                                            <input type="hidden" name="status" value="Approved">
                                            <button type="submit" class="bg-green-600 text-white px-3 py-1 text-xs rounded hover:bg-green-700 transition-colors">
                                                Approve
                                            </button>
                                        </form>
                                    <% } %>

                                    <%# Reject button %>
                                    <% if (app.status !== 'Rejected') { %>
                                        <form action="/admin/update-status" method="POST">
                                            <input type="hidden" name="id"     value="<%= app._id %>">
                                            <input type="hidden" name="status" value="Rejected">
                                            <button type="submit" class="bg-red-500 text-white px-3 py-1 text-xs rounded hover:bg-red-600 transition-colors">
                                                Reject
                                            </button>
                                        </form>
                                    <% } %>

                                    <%# Reset to Pending button %>
                                    <% if (app.status !== 'Pending') { %>
                                        <form action="/admin/update-status" method="POST">
                                            <input type="hidden" name="id"     value="<%= app._id %>">
                                            <input type="hidden" name="status" value="Pending">
                                            <button type="submit" class="bg-gray-400 text-white px-3 py-1 text-xs rounded hover:bg-gray-500 transition-colors">
                                                Reset
                                            </button>
                                        </form>
                                    <% } %>

                                </div>
                            </td>

                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>
</body>
</html>
